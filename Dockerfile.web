# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — builder
# Builds the Vite/React dashboard as static files.
#
# BASE_PATH must be "/" for production (no path prefix — the site lives at root).
# PORT is required by vite.config.ts but only affects the dev server, not the
# production build output.
# NODE_ENV=production suppresses the Replit-specific dev plugins (cartographer,
# devBanner) which are gated by REPL_ID in vite.config.ts.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-slim AS builder
WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

COPY . .

RUN pnpm install --frozen-lockfile

ENV BASE_PATH=/
ENV PORT=3000
ENV NODE_ENV=production

# Static files land in artifacts/dashboard/dist/public/
RUN pnpm --filter @workspace/dashboard run build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — runner
# nginx:alpine serves the static files and proxies /api/ to the api container.
# ─────────────────────────────────────────────────────────────────────────────
FROM nginx:alpine AS runner

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /workspace/artifacts/dashboard/dist/public/ /usr/share/nginx/html/

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
